# URL of the backend signaling server.
# For local development the defaults below work out of the box.
# In production set VITE_SOCKET_URL (or VITE_BACKEND_URL) to your deployed
# backend URL, e.g.:
#   VITE_SOCKET_URL=https://sharing-hhhe.onrender.com
VITE_BACKEND_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
