PORT=4000
NODE_ENV=development

# Comma-separated list of allowed frontend origins.
# For local development, the default (http://localhost:5173) is used when this is unset.
# In production you MUST set this to your deployed frontend URL(s), e.g.:
#   FRONTEND_URL=https://sharing-hhhe.onrender.com
# Multiple origins (e.g. production + local dev):
#   FRONTEND_URL=https://sharing-hhhe.onrender.com,http://localhost:5173
FRONTEND_URL=http://localhost:5173

ROOM_TIMEOUT_MS=300000
MAX_ROOMS=10000

# ── Rate limiting ──────────────────────────────────────────────────────────────
# Maximum HTTP requests per IP per window (default: 200).
# Lower this in production if abuse is observed.
# RATE_LIMIT_MAX=200
# RATE_LIMIT_WINDOW_MS=60000

